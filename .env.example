# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# (Опционально) ID администратора — для отладочных команд
ADMIN_ID=

# Путь к ffmpeg, если он не в PATH
FFMPEG_PATH=ffmpeg

# Максимальный размер загружаемого файла, МБ
MAX_UPLOAD_MB=20

# Логирование: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Очистка временных файлов старше N часов
TMP_MAX_AGE_HOURS=24

# Защита от тяжёлых рендеров
MAX_RENDER_SECONDS=180
MAX_RENDER_FRAMES=180
MAX_PARALLEL_RENDERS=2
MAX_USER_QUEUE=1
